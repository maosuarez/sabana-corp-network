-- Reto 2 (Base de Datos) — esquema y datos semilla del helpdesk de Sabana Corp.
-- Se ejecuta contra la base de datos definida por MYSQL_DATABASE (ver docker-compose.yml).
-- Este archivo es una PLANTILLA: entrypoint-wrapper.sh sustituye las variables ${...} en runtime.

-- Cuenta de aplicación que usa la Web App para conectarse (ver services/webapp/src/config.php). Son
-- estas mismas credenciales las que se filtran a través de /api/internal/admin/database tras el bypass
-- de JWT (Reto 1, vulnerabilidad #5b), y las que el participante usa para conectarse directamente a
-- MariaDB y volcar la tabla `users` (Reto 2).
CREATE USER IF NOT EXISTS '${DB_APP_USER}'@'%' IDENTIFIED BY '${DB_APP_PASSWORD}';
GRANT ALL PRIVILEGES ON *.* TO '${DB_APP_USER}'@'%';
FLUSH PRIVILEGES;

CREATE TABLE IF NOT EXISTS users (
    id            INT AUTO_INCREMENT PRIMARY KEY,
    username      VARCHAR(64) NOT NULL UNIQUE,
    -- VULN: contraseñas de usuarios almacenadas como MD5 sin salt (Reto 2). Intencionalmente
    -- crackeable con hashcat/rainbow tables — esta es la vulnerabilidad del reto, no un descuido.
    password_md5  CHAR(32) NOT NULL,
    role          ENUM('employee', 'it', 'admin') NOT NULL DEFAULT 'employee',
    full_name     VARCHAR(128) NOT NULL,
    email         VARCHAR(128) NOT NULL
);

CREATE TABLE IF NOT EXISTS tickets (
    id                    INT AUTO_INCREMENT PRIMARY KEY,
    subject               VARCHAR(255) NOT NULL,
    description           TEXT NOT NULL,
    attachment_filename   VARCHAR(255) DEFAULT NULL,
    created_by            INT NOT NULL,
    assigned_to           INT DEFAULT NULL,
    status                ENUM('open', 'in_progress', 'closed') NOT NULL DEFAULT 'open',
    FOREIGN KEY (created_by) REFERENCES users(id),
    FOREIGN KEY (assigned_to) REFERENCES users(id)
);

CREATE TABLE IF NOT EXISTS comments (
    id          INT AUTO_INCREMENT PRIMARY KEY,
    ticket_id   INT NOT NULL,
    author      VARCHAR(64) NOT NULL,
    body        TEXT NOT NULL,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (ticket_id) REFERENCES tickets(id)
);

-- Reto 2: nota interna que entrega la flag de puntuación una vez el participante alcanza acceso de
-- lectura a la base de datos con las credenciales filtradas por el Reto 1 (endpoint interno + bypass
-- de JWT). No es un hash a crackear: sería inviable crackear por diccionario un valor de flag aleatorio.
CREATE TABLE IF NOT EXISTS system_notes (
    id       INT AUTO_INCREMENT PRIMARY KEY,
    content  TEXT NOT NULL
);

