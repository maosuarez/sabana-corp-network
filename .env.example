# Plantilla de variables de entorno del laboratorio Sabana Corp Network.
#
# Copiar a `.env` (ignorado por git) y reemplazar los valores ficticios antes de levantar el laboratorio.
# Ver reglas completas en CLAUDE.md, seccion "Reglas para mantener consistencia entre flags".
#
# NUNCA commitear un `.env` con valores reales: ni las flags SABANA{...} ni los secretos de progresion
# especificos de este despliegue (PIVOT_SSH_PASSWORD, BOT_SECRET, credenciales de base de datos).

# ---------------------------------------------------------------------------
# Flags de puntuacion (formato SABANA{...}, una por reto/hito)
# ---------------------------------------------------------------------------

# Reto 1 (Web App) - se obtiene robando la cookie de sesion del admin via Stored XSS.
FLAG_WEBAPP_XSS=SABANA{ejemplo_no_es_la_flag_real_xss}

# Reto 1 (Web App, opcional) - se obtiene leyendo un archivo especifico via el LFI de adjuntos.
FLAG_WEBAPP_LFI=SABANA{ejemplo_no_es_la_flag_real_lfi}

# Reto 2 (Base de Datos) - se obtiene al alcanzar acceso de lectura con las credenciales filtradas.
FLAG_DATABASE=SABANA{ejemplo_no_es_la_flag_real_db}

# Reto 3 (Linux Server) - flag final, en /root/secrets.txt tras escalar a root.
FLAG_LINUXSERVER_ROOT=SABANA{ejemplo_no_es_la_flag_real_root}

# Reto 3.6 (Linux Server) - flag expuesta en argumentos del proceso 'flag' (ps aux / /proc/<pid>/cmdline).
# Puede tener el mismo valor que FLAG_LINUXSERVER_ROOT o uno distinto segun el diseño del evento.
FLAG_LINUXSERVER_PROC=SABANA{ejemplo_no_es_la_flag_real_proc}

# ---------------------------------------------------------------------------
# Secretos de progresion especificos de este despliegue (NO son flags, pero tampoco se commitean)
# ---------------------------------------------------------------------------

# Password del usuario SSH de bajo privilegio en Linux Server. Debe ser una contrasena
# realista/adivinable con diccionario (rockyou o similar), porque el participante la obtiene
# crackeando su hash MD5 en el Reto 2 - no la esta "filtrando" este .env, la esta calculando.
# Es la misma contrasena que la empleada "msilva" reutiliza en la tabla `users` de la Base de Datos
# (password reuse deliberado, ver services/database/init/01-seed.sql.template).
PIVOT_SSH_PASSWORD=changeme_weak_password

# Usuario SSH de bajo privilegio asociado a PIVOT_SSH_PASSWORD (mismo username que en `users.username`).
PIVOT_SSH_USER=msilva

# Secreto compartido entre el webapp y el contenedor xss-bot para que el bot pueda autenticarse
# como "admin" sin usar una contrasena que tambien aparezca en la tabla `users` (ver docs/context.md,
# decision de diseno #6). Generar con `openssl rand -hex 32` o similar; nunca debe llegar a los
# participantes.
BOT_SECRET=changeme_random_bot_secret

# ---------------------------------------------------------------------------
# Base de datos (MariaDB)
# ---------------------------------------------------------------------------

MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=sabana_helpdesk

# Credenciales de la cuenta de aplicacion que la Web App usa para conectarse a MariaDB. Son las mismas
# credenciales que se filtran a traves del endpoint /api/internal/admin/database tras el bypass de JWT
# (ver docs/context.md, Reto 1, paso 5b). Deben tener permisos suficientes para leer/escribir las tablas
# de la app y para que el participante pueda hacer un dump de `users` una vez las obtiene.
DB_APP_USER=helpdesk_app
DB_APP_PASSWORD=changeme_db_app_password

# ---------------------------------------------------------------------------
# Web Application
# ---------------------------------------------------------------------------

DB_HOST=database
DB_NAME=sabana_helpdesk

# Secreto usado unicamente para FIRMAR JWTs nuevos al emitirlos. Su valor real es irrelevante para la
# vulnerabilidad del reto: el backend deliberadamente NO verifica la firma al decodificar (ver
# docs/context.md, decision de diseno #5), asi que este secreto no necesita mantenerse "seguro" para que
# el reto funcione - se trata igual que un secreto mas por higiene, no porque el reto dependa de ello.
JWT_SIGNING_SECRET=changeme_jwt_signing_secret

# ---------------------------------------------------------------------------
# xss-bot (servicio de soporte, no es un reto)
# ---------------------------------------------------------------------------

WEBAPP_BASE_URL=http://webapp:80
BOT_VISIT_INTERVAL_SECONDS=30
